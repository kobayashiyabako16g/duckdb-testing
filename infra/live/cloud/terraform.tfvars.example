# ── GCP ─────────────────────────────────────────────────────
project_id = "your-gcp-project-id"
region     = "asia-northeast1"
image_tag  = "latest"

gcs_bucket_name = "your-gcs-bucket-name"

allow_unauthenticated   = true
cloud_run_min_instances = 0
cloud_run_max_instances = 10

# ── 1Password ────────────────────────────────────────────────
# 推奨: 1Password app にサインインした状態で実行
# 必要なら対象アカウントを op CLI で確認して指定
# export OP_ACCOUNT="my.1password.com"
# op account list
# onepassword_vault_name            = "Terraform"

# ── Cloud SQL (PostgreSQL) ──────────────────────────────────────
# デフォルト値でよければ指定不要。カスタマイズする場合のみ記述。
# database_name          = "duckdb_testing"
# database_user          = "duckdb_user"
enable_auto_start_stop = true  # Cloud Scheduler による自動停止・起動

# ── Cloudflare Access (API JWT 検証用) ────────────────────────
# cf_access_aud は Terraform が cloudflare_zero_trust_access_application から自動取得するため不要
cf_access_team_domain = "your-team.cloudflareaccess.com"

# ── Cloudflare (Access) ──────────────────────────────────────
cloudflare_api_token  = "your-cloudflare-api-token"
cloudflare_account_id = "your-cloudflare-account-id"

# Cloudflare DNS でプロキシ有効（orange-cloud）のカスタムドメイン
# Cloud Run Domain Mapping の設定も別途必要 (README 参照)
app_domain = "app.your-domain.com"

cloudflare_allowed_email_domains = ["your-company.com"]

# ── Google OAuth (Cloudflare Access の Identity Provider 用) ─────
# 設定すると CF Access のログイン画面に「Sign in with Google」が出る。
# 空のままでも CF Access のデフォルト IdP (One-Time PIN 等) で動作する。
google_oauth_client_id     = ""
google_oauth_client_secret = ""
