# 本番環境設定例
# 使用方法: terragrunt plan --var-file prod.tfvars

# ── GCP ─────────────────────────────────────────────────────
project_id = "your-gcp-project-id-prod"

# ── Cloud Run ────────────────────────────────────────────────
allow_unauthenticated   = false  # Cloudflare Access でのみ許可
cloud_run_min_instances = 2      # HA構成（コールドスタート回避）
cloud_run_max_instances = 20     # 本番スケール

# ── Cloud SQL ────────────────────────────────────────────────
enable_auto_start_stop = false   # 常時稼働（SLA要件）

# ── Cloudflare + Google OAuth ─────────────────────────────────
# (terraform.tfvars から読み込み)
