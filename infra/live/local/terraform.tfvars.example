# ── ローカル開発環境 ──────────────────────────────────────────
# このファイルを terraform.tfvars にコピーして値を埋める。
# terraform.tfvars は .gitignore 済み (秘匿情報を含む可能性があるため)。

project_id      = "your-gcp-project-id"
gcs_bucket_name = "your-local-data-bucket-name"

# SA に成り代わって署名付き URL を発行する開発者プリンシパル。
# user:、group:、serviceAccount: のいずれかのプレフィックス付き。
developer_principals = [
  "user:you@example.com",
]

# region / bucket_location / service_account_id は live/local/terragrunt.hcl 等で既定値あり。
# 上書きしたい場合のみ設定する。
# region             = "asia-northeast1"
# bucket_location    = "ASIA"
# service_account_id = "duckdb-testing-api-local"
