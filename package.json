{
  "name": "duckdb-testing",
  "version": "1.0.0",
  "description": "",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build:api": "dotenvx run -- turbo run build --filter=@apps/api... --ui=tui",
    "build:front": "dotenvx run -- turbo run build --filter=@apps/front...",
    "dev:front": "dotenvx run -- turbo run dev --filter=@apps/front... --ui=tui",
    "dev:api": "dotenvx run -- turbo run dev --filter=@apps/api... --ui=tui",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "env:set": "dotenvx set",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.21"
  }
}
