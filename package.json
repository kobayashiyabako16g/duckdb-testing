{
  "name": "duckdb-testing",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build:api": "dotenvx run -- turbo run build --filter=@apps/api... --ui=tui",
    "build:front": "dotenvx run -- turbo run build --filter=@apps/front...",
    "dev:all": "APP_ENV=development dotenvx run -- turbo run dev --ui=tui",
    "dev:front": "APP_ENV=development dotenvx run -- turbo run dev --filter=@apps/front... --ui=tui",
    "dev:api": "APP_ENV=development dotenvx run -- turbo run dev --filter=@apps/api... --ui=tui",
    "db:generate": "dotenvx run -- turbo run db:generate --filter=@apps/api... --ui=tui",
    "db:migrate": "dotenvx run -- turbo run db:migrate --filter=@apps/api... --ui=tui",
    "db:studio": "dotenvx run -- turbo run db:studio --filter=@apps/api... --ui=tui",
    "db:push": "dotenvx run -- turbo run db:push --filter=@apps/api... --ui=tui",
    "db:seed": "dotenvx run -- turbo run db:seed --filter=@apps/api... --ui=tui",
    "gen:openapi": "dotenvx run -- turbo run gen:openapi --filter=@apps/api",
    "gen:api-types": "dotenvx run -- turbo run gen:api-types --filter=@apps/front",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "env:set": "dotenvx set",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@faker-js/faker": "^10.5.0",
    "@types/node": "^26.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "turbo": "2.9.18"
  },
  "packageManager": "pnpm@10.32.1"
}
