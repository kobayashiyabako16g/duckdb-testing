{
  "$schema": "https://v2-8-20.turborepo.dev/schema.json",
  "globalEnv": [
    "APP_ENV",
    "DB_USER",
    "DB_PASSWORD",
    "DB_NAME",
    "DB_PORT",
    "DATABASE_URL",
    "GCS_BUCKET_NAME",
    "DEV_USER_EMAIL",
    "CF_ACCESS_TEAM_DOMAIN",
    "CF_ACCESS_AUD",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "quality": {
      "dependsOn": ["lint", "format:check"]
    },
    "quality:fix": {
      "dependsOn": ["lint:fix", "format"]
    },
    "lint": {
      "cache": true
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": true
    },
    "test": {
      "cache": true
    }
  }
}
